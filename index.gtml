<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>صانع السير الذاتية الذكي بنظام ATS - النسخة المتقدمة</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --bg: #f8fafc;
            --text: #1e293b;
            --border: #cbd5e1;
            --success: #059669;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cairo', 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            line-height: 1.6;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 20px;
        }

        h1 {
            color: var(--primary);
            font-size: 28px;
            margin-bottom: 10px;
        }

        .selectors {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
            background: #f1f5f9;
            padding: 15px;
            border-radius: 8px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .repeater-item {
            background: #f8fafc;
            border: 1px solid var(--border);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            position: relative;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 5px;
            font-size: 14px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-family: inherit;
            font-size: 14px;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        button {
            background-color: var(--primary);
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            width: 100%;
            font-family: inherit;
        }

        button:hover {
            background-color: var(--primary-dark);
        }

        .btn-add {
            background-color: #e2e8f0;
            color: var(--text);
            padding: 8px 16px;
            font-size: 13px;
            margin-bottom: 20px;
            width: auto;
            display: inline-block;
        }
        .btn-add:hover { background-color: #cbd5e1; }

        .btn-remove {
            background-color: #ef4444;
            color: white;
            padding: 4px 8px;
            font-size: 12px;
            width: auto;
            position: absolute;
            top: 10px;
            left: 10px;
        }
        html[dir="ltr"] .btn-remove { left: auto; right: 10px; }
        .btn-remove:hover { background-color: #dc2626; }

        .dynamic-section {
            display: none;
            border-top: 1px dashed var(--border);
            padding-top: 20px;
            margin-top: 20px;
        }

        .active {
            display: block;
        }

        #cv-preview {
            display: none;
            background: white;
            color: #000000;
            padding: 40px;
            margin-top: 40px;
            border: 1px solid #000000;
            font-family: Arial, sans-serif;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .cv-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .cv-name {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .cv-contact {
            font-size: 12px;
            margin-bottom: 15px;
        }

        .cv-section-title {
            font-size: 14px;
            font-weight: bold;
            border-bottom: 1px solid #000;
            text-transform: uppercase;
            margin-top: 15px;
            margin-bottom: 8px;
            padding-bottom: 2px;
        }

        .cv-item {
            margin-bottom: 12px;
            font-size: 13px;
        }

        .cv-item-header {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
        }

        .cv-bullet-list {
            margin-left: 20px;
            margin-right: 20px;
            list-style-type: square;
        }

        .cv-bullet-list li {
            font-size: 13px;
            margin-bottom: 3px;
        }

        .action-btns {
            display: none;
            gap: 15px;
            margin-top: 20px;
        }

        @media print {
            body * { visibility: hidden; }
            #cv-preview, #cv-preview * { visibility: visible; }
            #cv-preview { position: absolute; left: 0; top: 0; width: 100%; border: none; padding: 0; }
        }
    </style>
</head>
<body>

<div class="container" id="main-form">
    <header>
        <h1 id="main-title">صانع السير الذاتية الذكي (ATS)</h1>
        <p id="main-subtitle">يدعم إضافة خبرات وتعليم متعدد مع إدراج اللغات والمهارات</p>
    </header>

    <div class="selectors">
        <div class="form-group">
            <label for="lang-select">لغة السيرة الذاتية / CV Language</label>
            <select id="lang-select" onchange="toggleLanguage()">
                <option value="ar">العربية (Arabic)</option>
                <option value="en">الإنجليزية (English)</option>
            </select>
        </div>
        <div class="form-group">
            <label id="lbl-experience" for="exp-select">الحالة المهنية</label>
            <select id="exp-select" onchange="toggleExperiencePaths()">
                <option value="experienced">لدي خبرة عمل (Experienced)</option>
                <option value="fresh">خريج جديد / بدون خبرة (No Experience)</option>
            </select>
        </div>
    </div>

    <form id="cv-data-form" onsubmit="generateCV(event)">
        <!-- 1. البيانات الشخصية -->
        <h3 id="sec-personal" style="margin-bottom: 15px; color: var(--primary);">1. البيانات الشخصية والاتصال</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div class="form-group">
                <label id="lbl-name">الاسم بالكامل</label>
                <input type="text" id="input-name" required placeholder="كريم محمد">
            </div>
            <div class="form-group">
                <label id="lbl-title">المسمى الوظيفي المستهدف</label>
                <input type="text" id="input-title" required placeholder="محاسب قانوني">
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;">
            <div class="form-group">
                <label id="lbl-email">البريد الإلكتروني</label>
                <input type="email" id="input-email" required placeholder="name@example.com">
            </div>
            <div class="form-group">
                <label id="lbl-phone">رقم الهاتف</label>
                <input type="tel" id="input-phone" required placeholder="01xxxxxxxxx">
            </div>
            <div class="form-group">
                <label id="lbl-location">المدينة / الدولة</label>
                <input type="text" id="input-location" required placeholder="القاهرة، مصر">
            </div>
        </div>

        <div class="form-group">
            <label id="lbl-linkedin">رابط حساب لينكد إن (LinkedIn)</label>
            <input type="url" id="input-linkedin" placeholder="https://linkedin.com/in/username">
        </div>

        <div class="form-group">
            <label id="lbl-summary">الملخص المهني / النبذة التعريفية</label>
            <textarea id="input-summary" rows="3" required placeholder="اكتب نبذة مختصرة تلخص خبرتك وشغفك المهني..."></textarea>
        </div>

        <!-- 2. قسم التعليم المتعدد -->
        <h3 id="sec-edu-title" style="margin-top: 20px; margin-bottom: 10px; color: var(--primary);">2. التعليم والدراسة</h3>
        <div id="education-container">
            <!-- سيتم توليد بنود التعليم هنا -->
        </div>
        <button type="button" class="btn-add" id="btn-add-edu" onclick="addEducationField()">+ إضافة شهادة/تعليم آخر</button>

        <!-- 3. المهارات واللغات -->
        <h3 id="sec-skills-lang" style="margin-top: 20px; margin-bottom: 15px; color: var(--primary);">3. المهارات واللغات</h3>
        <div class="form-group">
            <label id="lbl-skills">المهارات المهنية والتقنية (افصل بينها بفاصلة ,)</label>
            <input type="text" id="input-skills" required placeholder="إدارة الحسابات, تحليل البيانات, Excel, حل المشكلات">
        </div>
        <div class="form-group">
            <label id="lbl-languages">اللغات المتقنة (افصل بينها بفاصلة ,)</label>
            <input type="text" id="input-languages" required placeholder="العربية (اللغة الأم), الإنجليزية (متقدم)">
        </div>

        <!-- 4. مسار أصحاب الخبرة (خبرات متعددة) -->
        <div id="section-experienced" class="dynamic-section active">
            <h3 id="sec-work" style="margin-bottom: 10px; color: var(--primary);">4. الخبرات المهنية السابقة</h3>
            <div id="experience-container">
                <!-- سيتم توليد بنود الخبرات هنا -->
            </div>
            <button type="button" class="btn-add" id="btn-add-exp" onclick="addExperienceField()">+ إضافة خبرة مهنية أخرى</button>
        </div>

        <!-- 5. مسار الخريجين الجدد / بدون خبرة -->
        <div id="section-fresh" class="dynamic-section">
            <h3 id="sec-projects" style="margin-bottom: 15px; color: var(--primary);">4. المشاريع والأنشطة التطوعية</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <label id="lbl-proj-name">اسم المشروع أو النشاط</label>
                    <input type="text" id="input-project-name" placeholder="مشروع تخرج نظام محاسبي ذكي">
                </div>
                <div class="form-group">
                    <label id="lbl-proj-role">دورك فيه</label>
                    <input type="text" id="input-project-role" placeholder="قائد الفريق">
                </div>
            </div>
            <div class="form-group">
                <label id="lbl-proj-desc">شرح مختصر للمشروع (ضع كل نقطة في سطر منفصل)</label>
                <textarea id="input-project-desc" rows="4" placeholder="- قمت بإعداد الهيكل المالي كاملاً.&#10;- إدارة وتنسيق العمل بين أفراد الفريق."></textarea>
            </div>
        </div>

        <button type="submit" id="btn-submit" style="margin-top: 20px;">توليد السيرة الذاتية المتوافقة مع ATS ↑</button>
    </form>
</div>

<!-- منطقة المعاينة والطباعة -->
<div id="cv-preview"></div>

<div class="action-btns" id="action-area" style="max-width: 800px; margin: 20px auto; display:none;">
    <button onclick="window.print()" style="background-color: var(--success);">تحميل كـ PDF / طباعة السيرة الذاتية</button>
    <button onclick="editForm()" style="background-color: #64748b;">تعديل البيانات وعودة للخلف</button>
</div>

<script>
    const dictionary = {
        ar: {
            title: "صانع السير الذاتية الذكي (ATS)",
            subtitle: "يدعم إضافة خبرات وتعليم متعدد مع إدراج اللغات والمهارات",
            lblExperience: "الحالة المهنية",
            secPersonal: "1. البيانات الشخصية والاتصال",
            lblName: "الاسم بالكامل",
            lblTitle: "المسمى الوظيفي المستهدف",
            lblEmail: "البريد الإلكتروني",
            lblPhone: "رقم الهاتف",
            lblLocation: "المدينة / الدولة",
            lblLinkedin: "رابط حساب لينكد إن (LinkedIn)",
            lblSummary: "الملخص المهني / النبذة التعريفية",
            secEduTitle: "2. التعليم والدراسة",
            btnAddEdu: "+ إضافة شهادة/تعليم آخر",
            secSkillsLang: "3. المهارات واللغات",
            lblSkills: "المهارات المهنية والتقنية (افصل بينها بفاصلة ,)",
            lblLanguages: "اللغات المتقنة (افصل بينها بفاصلة ,)",
            secWork: "4. الخبرات المهنية السابقة",
            btnAddExp: "+ إضافة خبرة مهنية أخرى",
            secProjects: "4. المشاريع والأنشطة التطوعية",
            lblProjName: "اسم المشروع أو النشاط",
            lblProjRole: "دورك فيه",
            lblProjDesc: "شرح مختصر للمشروع (ضع كل نقطة في سطر منفصل)",
            btnSubmit: "توليد السيرة الذاتية المتوافقة مع ATS ↑",
            placeholderEdu: "بكالوريوس التجارة - جامعة بنها",
            placeholderYear: "2026",
            placeholderComp: "اسم الشركة أو المؤسسة",
            placeholderJob: "المسمى الوظيفي",
            placeholderFrom: "من تاريخ",
            placeholderTo: "إلى تاريخ",
            placeholderResp: "المهام والإنجازات (كل مهمة في سطر)",
            cvHeaders: { exp: "الخبرات المهنية", edu: "التعليم", skills: "المهارات", lang: "اللغات", proj: "المشاريع والأنشطة" }
        },
        en: {
            title: "Smart ATS CV Builder",
            subtitle: "Supports multiple experiences & educations with languages and skills",
            lblExperience: "Professional Status",
            secPersonal: "1. Personal Information & Contact",
            lblName: "Full Name",
            lblTitle: "Target Job Title",
            lblEmail: "Email Address",
            lblPhone: "Phone Number",
            lblLocation: "City, Country",
            lblLinkedin: "LinkedIn Profile URL",
            lblSummary: "Professional Summary",
            secEduTitle: "2. Education & Academic Background",
            btnAddEdu: "+ Add Another Education",
            secSkillsLang: "3. Skills & Languages",
            lblSkills: "Professional & Technical Skills (Separate with commas ,)",
            lblLanguages: "Languages (Separate with commas ,)",
            secWork: "4. Professional Experience",
            btnAddExp: "+ Add Another Work Experience",
            secProjects: "4. Projects & Volunteering",
            lblProjName: "Project / Activity Name",
            lblProjRole: "Your Role",
            lblProjDesc: "Short Description (One per line)",
            btnSubmit: "Generate ATS-Friendly CV ↑",
            placeholderEdu: "B.Sc. in Commerce - Benha University",
            placeholderYear: "2026",
            placeholderComp: "Company Name",
            placeholderJob: "Job Title",
            placeholderFrom: "From Date",
            placeholderTo: "To Date",
            placeholderResp: "Responsibilities & Achievements (One per line)",
            cvHeaders: { exp: "Professional Experience", edu: "Education", skills: "Skills", lang: "Languages", proj: "Projects & Activities" }
        }
    };

    // دوال ديناميكية لإضافة وحذف حقول التعليم
    function addEducationField(valueEdu = '', valueYear = '') {
        const container = document.getElementById('education-container');
        const lang = document.getElementById('lang-select').value;
        const dict = dictionary[lang];
        
        const div = document.createElement('div');
        div.className = 'repeater-item edu-item';
        div.innerHTML = `
            <button type="button" class="btn-remove" onclick="this.parentElement.remove()">X</button>
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 15px; margin-top: 10px;">
                <div class="form-group">
                    <input type="text" class="edu-input-name" required placeholder="${dict.placeholderEdu}" value="${valueEdu}">
                </div>
                <div class="form-group">
                    <input type="text" class="edu-input-year" required placeholder="${dict.placeholderYear}" value="${valueYear}">
                </div>
            </div>
        `;
        container.appendChild(div);
    }

    // دوال ديناميكية لإضافة وحذف حقول الخبرة المهنية
    function addExperienceField(comp='', job='', from='', to='', resp='') {
        const container = document.getElementById('experience-container');
        const lang = document.getElementById('lang-select').value;
        const dict = dictionary[lang];

        const div = document.createElement('div');
        div.className = 'repeater-item exp-item';
        div.innerHTML = `
            <button type="button" class="btn-remove" onclick="this.parentElement.remove()">X</button>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 10px;">
                <div class="form-group">
                    <input type="text" class="exp-input-comp" required placeholder="${dict.placeholderComp}" value="${comp}">
                </div>
                <div class="form-group">
                    <input type="text" class="exp-input-job" required placeholder="${dict.placeholderJob}" value="${job}">
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div class="form-group">
                    <input type="text" class="exp-input-from" required placeholder="${dict.placeholderFrom}" value="${from}">
                </div>
                <div class="form-group">
                    <input type="text" class="exp-input-to" required placeholder="${dict.placeholderTo}" value="${to}">
                </div>
            </div>
            <div class="form-group">
                <textarea class="exp-input-resp" rows="3" required placeholder="${dict.placeholderResp}">${resp}</textarea>
            </div>
        `;
        container.appendChild(div);
    }

    function toggleLanguage() {
        const lang = document.getElementById('lang-select').value;
        const htmlTag = document.documentElement;
        htmlTag.dir = (lang === 'ar') ? "rtl" : "ltr";
        htmlTag.lang = lang;

        const dict = dictionary[lang];
        document.getElementById('main-title').innerText = dict.title;
        document.getElementById('main-subtitle').innerText = dict.subtitle;
        document.getElementById('lbl-experience').innerText = dict.lblExperience;
        document.getElementById('sec-personal').innerText = dict.secPersonal;
        document.getElementById('lbl-name').innerText = dict.lblName;
        document.getElementById('lbl-title').innerText = dict.lblTitle;
        document.getElementById('lbl-email').innerText = dict.lblEmail;
        document.getElementById('lbl-phone').innerText = dict.lblPhone;
        document.getElementById('lbl-location').innerText = dict.lblLocation;
        document.getElementById('lbl-linkedin').innerText = dict.lblLinkedin;
        document.getElementById('lbl-summary').innerText = dict.lblSummary;
        document.getElementById('sec-edu-title').innerText = dict.secEduTitle;
        document.getElementById('btn-add-edu').innerText = dict.btnAddEdu;
        document.getElementById('sec-skills-lang').innerText = dict.secSkillsLang;
        document.getElementById('lbl-skills').innerText = dict.lblSkills;
        document.getElementById('lbl-languages').innerText = dict.lblLanguages;
        document.getElementById('sec-work').in
